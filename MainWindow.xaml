<Window x:Class="FRANK_CHATBOT_PART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FRANK_CHATBOT_PART2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid x:Name="FfrmStart" Background="#FF4EB4AC">

        <Button 
            
        x:Name="btnstart"
        Content="Start"
        HorizontalAlignment="Left"
        Height="44"
        Margin="497,290,0,0"
        VerticalAlignment="Top"
        Width="116"
        Background="#FF201F1F"
        Foreground="White"
        FontWeight="Bold"
        FontSize="18"
        BorderBrush="#FF1421A6"
        Click="btnstart_Click">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="2"
                    CornerRadius="5">

                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>

        </Button>


        <Border 
            CornerRadius="4"
        Background="White"
        BorderBrush="#0B39B1"
        BorderThickness="2"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="468,222,0,0"
        Width="214"
        Height="27">

            <TextBox x:Name="txtName"
             Background="Transparent"
             BorderThickness="0"
             Padding="8,2"
             FontSize="16"
             VerticalContentAlignment="Center">

                <TextBox.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="0.096"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </TextBox.RenderTransform>

            </TextBox>
        </Border>


        <Label x:Name="lblName" Content="Name" HorizontalAlignment="Left" Margin="468,186,0,0" VerticalAlignment="Top" FontSize="16" Width="59" Foreground="White"/>
        <Image HorizontalAlignment="Left" Height="414" Margin="10,0,0,0" VerticalAlignment="Center" Width="338" Source="/cybeeimg.jpeg" Stretch="Fill"/>
        <Label x:Name="lblsubheading" Content="Cybersecurity Awareness Bot" HorizontalAlignment="Left" Margin="425,56,0,0" VerticalAlignment="Top" FontSize="20"/>

    </Grid>
</Window>
